# ---------------------------------------------------------------------------
# seven-ai-trading-bots — environment template
#
# EVERY variable below is OPTIONAL. The repository runs fully offline with no
# keys at all (synthetic data + offline Claude stub + paper brokers).
# Copy to `.env` and fill in only what you actually use. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# Anthropic API — enables real Claude classification (ch05/ch06 bots).
# Leave empty to use the deterministic offline stub classifier.
ANTHROPIC_API_KEY=

# Alpaca (equities & options; paper endpoint) — enables real paper-account
# wiring. Leave empty to use the built-in simulated paper ledger.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Discord webhook for trade notifications (ch02). Leave empty to print
# notifications to the console instead.
DISCORD_WEBHOOK_URL=

# Crypto exchange API keys (ch08 cash-and-carry). Trading permissions only —
# the book is explicit: do NOT enable withdrawal permissions on these keys.
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BYBIT_API_KEY=
BYBIT_SECRET_KEY=

# Data / feed providers (optional upgrades; offline fixtures used otherwise).
FMP_API_KEY=
UNUSUAL_WHALES_API_KEY=

# Fees the book refuses to hard-code ("verify at the source").
# 0.65 is the industry-typical per-contract default — VERIFY against Alpaca's
# current Brokerage Fee Schedule before relying on it (book ch11).
ALPACA_OPTION_FEE_PER_CONTRACT=0.65
